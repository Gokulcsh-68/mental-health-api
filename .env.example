APP_NAME=Lumen
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC

#[LOG]
LOG_CHANNEL=stack
LOG_SLACK_WEBHOOK_URL=

#[DB]
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=homestead
DB_USERNAME=homestead
DB_PASSWORD=secret
DB_ENGINE=InnoDB

CACHE_DRIVER=file
QUEUE_CONNECTION=sync

JWT_SECRET=

#[S3]
S3_KEY=
S3_SECRET=
S3_REGION=
S3_BUCKET=
S3_BASE_PATH=temp/
S3_PUBLIC_BASE_PATH='https://a2ztelehealth.s3.amazonaws.com/'

#[CURESELECT_MICROSERVICE]
CURESELECT_API_ENDPOINT=
CURESELECT_API_CLIENT_ID=
CURESELECT_API_CLIENT_SECRET=

#[HEALTH_SETTINGS]
PATIENT_HEALTH_RECORD_FREEZE_HOURS=24

#[TELECONSULT_SETTINGS]
DEFAULT_SERVICE_PROVIDER='tokbox'
